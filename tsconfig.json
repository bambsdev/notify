{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "types": ["@cloudflare/workers-types", "@types/bun"],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"]
}
